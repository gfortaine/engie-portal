{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "devCommand": "cd apps/portal && npx vite --port $PORT",
  "installCommand": "npm i -g pnpm@10.11.0 && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @engie-portal/portal build",
  "outputDirectory": "apps/portal/dist",
  "functions": {
    "api/**": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/trpc/:path*", "destination": "/api/trpc/[trpc]" },
    { "source": "/api/chat", "destination": "/api/chat/route" },
    { "source": "/api/sessions", "destination": "/api/sessions/route" },
    { "source": "/:path((?!api|assets|src|node_modules|@).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
